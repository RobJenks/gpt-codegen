{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": "./src",
    "types": ["vite/client"]
  },
  "include": ["src", "decs.d.ts"],
  "exclude": [
    "src/index.tsx",
    "src/App.test.tsx",
    "src/BpmnApp.tsx",
    "src/__BpmnApp.tsx",
    "src/reportWebVitals.tsx",
    "src/setupTests.tsx",
    "src/react-app-env.d.ts",
    "src/components/events",
    "src/components/ui/codeArea.tsx",
    "src/components/ui/outputCodeArea.tsx",
    "src/components/util/splitView.tsx",
    "src/components/util/splitViewVertical.tsx"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
